{
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=PetOwner;Trusted_Connection=true;TrustServerCertificate=true"
  },
  "Jwt": {
    "Issuer": "PetOwner.Api",
    "Audience": "PetOwner.Client",
    "ExpireMinutes": 60
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200"
    ]
  },
  "AdminSeed": {
    "Users": [],
    "Password": ""
  },
  "Stripe": {
    "SecretKey": "",
    "WebhookSecret": "",
    "PlatformFeePercent": 15
  },
  "OpenAI": {
    "ApiKey": "",
    "Model": "gpt-4o-mini",
    "MaxTokens": 1024
  },
  "BlobStorage": {
    "ConnectionString": "UseDevelopmentStorage=true",
    "ContainerName": "uploads",
    "MaxFileSizeMb": 10,
    "ThumbnailWidth": 300,
    "ThumbnailHeight": 300
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
