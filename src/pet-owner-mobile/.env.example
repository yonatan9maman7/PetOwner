# Copy to `.env` for local development. Do not commit `.env`.

EXPO_PUBLIC_API_URL=https://petowner-production.up.railway.app

# Sentry — client DSN (public). Used only outside __DEV__ on native.
EXPO_PUBLIC_SENTRY_DSN=YOUR_DSN_HERE

# Optional: separate Sentry events by channel (preview | production)
# EXPO_PUBLIC_APP_ENV=development

# EAS Build only (Expo dashboard secrets — never commit):
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug
