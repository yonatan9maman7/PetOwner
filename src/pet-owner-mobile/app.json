{
  "expo": {
    "name": "pet-owner-mobile",
    "slug": "pet-owner-mobile",
    "scheme": "petowner",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.petowner.app",
      "usesAppleSignIn": true,
      "entitlements": {
        "com.apple.developer.applesignin": [
          "Default"
        ]
      },
      "infoPlist": {
        "NSFaceIDUsageDescription": "Allow PetOwner to use Face ID for fast and secure sign-in."
      }
    },
    "android": {
      "package": "com.petowner.app",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "useNextNotificationsApi": true,
      "notification": {
        "icon": "./assets/adaptive-icon.png",
        "color": "#000000"
      },
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "a152acc8-00c8-4730-aee4-08354bf924d1"
      }
    },
    "plugins": [
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-font",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow PetOwner to use Face ID for fast and secure sign-in."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/adaptive-icon.png",
          "color": "#000000",
          "sounds": [],
          "mode": "production"
        }
      ],
      "expo-web-browser",
      "expo-apple-authentication"
    ],
    "owner": "mamanyon"
  }
}
